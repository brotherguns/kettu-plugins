{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react",
    "jsxFactory": "React.createElement",
    "jsxFragmentFactory": "React.Fragment",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["react"]
  },
  "include": ["plugins", "lib", "vendetta.d.ts"],
  "exclude": ["**/*.test.ts", "node_modules", "dist"]
}
